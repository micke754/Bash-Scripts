#!/bin/bash
set -euo pipefail

# Ensure the clipboard has content before sending.
if ! xsel --clipboard --output | grep -q .; then
    echo "Clipboard is empty. Nothing to send." >&2
    exit 1
fi

# The return should not be bracketed.
tmux send-keys -t right C-l

# Stream clipboard into tmux buffer to avoid command-size limits,
# then paste using tmux bracketed paste mode.
xsel --clipboard --output | tmux load-buffer -
tmux paste-buffer -p -t right
tmux send-keys -t right Enter
